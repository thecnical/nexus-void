# NEXUS-VOID Dashboard Environment Configuration
# Copy this file to .env.local and adjust for your setup

# Backend WebSocket URL (local development)
REACT_APP_WS_URL=ws://localhost:8080/ws

# Backend REST API URL (local development)
REACT_APP_API_URL=http://localhost:8080/api

# For Render deployment, use your backend service URL:
# REACT_APP_WS_URL=wss://nexus-void-backend.onrender.com/ws
# REACT_APP_API_URL=https://nexus-void-backend.onrender.com/api
